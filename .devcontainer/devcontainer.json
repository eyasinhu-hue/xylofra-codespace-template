{
  "name": "Xylofra Codespace Runner",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/sshd:1": {}
  },
  "forwardPorts": [3939, 3000, 5173, 8080, 4321],
  "portsAttributes": {
    "3939": {
      "label": "Xylofra Runner",
      "visibility": "public",
      "onAutoForward": "silent"
    },
    "3000": { "label": "User App (3000)", "visibility": "public", "onAutoForward": "silent" },
    "5173": { "label": "User App (Vite)", "visibility": "public", "onAutoForward": "silent" },
    "8080": { "label": "User App (8080)", "visibility": "public", "onAutoForward": "silent" },
    "4321": { "label": "User App (Astro)", "visibility": "public", "onAutoForward": "silent" }
  },
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "postStartCommand": "bash .devcontainer/postStart.sh",
  "containerEnv": {
    "RUNNER_PORT": "3939"
  },
  "remoteUser": "node",
  "hostRequirements": {
    "cpus": 2,
    "memory": "4gb",
    "storage": "32gb"
  }
}
